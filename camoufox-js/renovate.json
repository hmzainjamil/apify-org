{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"dependencyDashboard": false,
	"minimumReleaseAge": "1 day",
	"internalChecksFilter": "strict",
	"packageRules": [
		{
			"matchPackageNames": [
				"@apify/*",
				"@crawlee/*",
				"apify-client",
				"apify",
				"crawlee",
				"got-scraping"
			],
			"minimumReleaseAge": "0 days"
		}
	]
}
